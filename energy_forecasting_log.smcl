. *
. * 4. EXPLORATORY DATA ANALYSIS
. *
. 
. * 4.1 Time series plots
. tsline demand_gwh generation_gwh, ///
>     title("Malawi: Monthly Energy Demand vs Generation, 2018–2024") ///
>     subtitle("GWh per month") ///
>     ytitle("GWh") xtitle("Month") ///
>     legend(label(1 "Demand") label(2 "Generation")) ///
>     lcolor(navy red) lwidth(medthick medthick) ///
>     graphregion(color(white)) bgcolor(white)
{res}{txt}
{com}. graph export "fig1_demand_vs_generation.png", replace width(1200)
{txt}(file fig1_demand_vs_generation.png written in PNG format)

{com}. 
. * 4.2 Unmet demand trend
. tsline unmet_demand_gwh, ///
>     title("Monthly Unmet Energy Demand, 2018–2024") ///
>     ytitle("GWh") xtitle("Month") ///
>     lcolor(red) lwidth(medthick) ///
>     yline(0, lcolor(gray) lpattern(dash)) ///
>     graphregion(color(white)) bgcolor(white)
{res}{txt}
{com}. graph export "fig2_unmet_demand.png", replace width(1200)
{txt}(file fig2_unmet_demand.png written in PNG format)

