{com}. 
. * Generate Stata time variable (monthly)
. gen t = ym(year, month)
{txt}
{com}. format t %tm
{txt}
{com}. tsset t, monthly
{res}{txt}{col 9}time variable:  {res}{col 25}t, 2018m1 to 2024m12
{txt}{col 17}delta:  {res}1 month
{txt}
{com}. 
. label var t                 "Time (monthly)"
{txt}
{com}. label var generation_gwh    "Total generation (GWh)"
{txt}
{com}. label var demand_gwh        "Total demand (GWh)"
{txt}
{com}. label var peak_demand_mw    "Peak demand (MW)"
{txt}
{com}. label var capacity_mw       "Installed capacity (MW)"
{txt}
{com}. label var hydro_gwh         "Hydro generation (GWh)"
{txt}
{com}. label var thermal_gwh       "Thermal generation (GWh)"
{txt}
{com}. label var load_factor_pct   "Load factor (%)"
{txt}
{com}. label var unmet_demand_gwh  "Unmet demand (GWh)"
{txt}
{com}. label var system_losses_pct "System losses (%)"
{txt}
{com}. label var rainfall_mm       "Monthly rainfall (mm)"
{txt}
{com}. label var gdp_index         "GDP index (2018=100)"
{txt}
{com}. 
. * Check for missing values
. misstable summarize
{txt}(variables nonmissing or string)

{com}. 
{txt}end of do-file

{com}. do "C:\Users\mary\AppData\Local\Temp\STD01000000.tmp"
{txt}
{com}. *
. * 2. COMPUTE OPERATIONAL KPIs
. *
. 
. * 2.1 Generation adequacy ratio (generation / demand)
. gen adequacy_ratio = generation_gwh / demand_gwh
{txt}
{com}. label var adequacy_ratio "Generation adequacy ratio"
{txt}
{com}. 
. * 2.2 Capacity utilisation (generation vs installed capacity equivalent)
. *     Installed capacity MWh/month = capacity_mw * 24 * 30 / 1000
. gen capacity_util_pct = (generation_gwh / (capacity_mw * 24 * 30 / 1000)) * 100
{txt}
{com}. label var capacity_util_pct "Capacity utilisation (%)"
{txt}
{com}. 
. * 2.3 Energy access gap (unmet demand as % of total demand)
. gen access_gap_pct = (unmet_demand_gwh / demand_gwh) * 100
{txt}
{com}. label var access_gap_pct "Energy access gap (%)"
{txt}
{com}. 
. * 2.4 Hydro dependency ratio
. gen hydro_share_pct = (hydro_gwh / generation_gwh) * 100
{txt}
{com}. label var hydro_share_pct "Hydro share of generation (%)"
{txt}
{com}. 
. * 2.5 Supply reliability index (100 - access_gap_pct)
. gen reliability_idx = 100 - access_gap_pct
{txt}
{com}. label var reliability_idx "Supply reliability index"
{txt}
{com}. 
. * 2.6 Year-on-year demand growth rate
. sort t
{txt}
{com}. gen demand_growth_yoy = (demand_gwh - l12.demand_gwh) / l12.demand_gwh * 100
{txt}(12 missing values generated)

{com}. label var demand_growth_yoy "Year-on-year demand growth (%)"
{txt}
{com}. 
. * 2.7 12-month rolling average demand
. tssmooth ma demand_ma12 = demand_gwh, window(6 1 6)
{txt}The smoother applied was
{res}{p 5 5 5}(1/13)*[x(t-6) + x(t-5) + x(t-4) + x(t-3) + x(t-2) + x(t-1) + 1*x(t) + x(t+1) + x(t+2) + x(t+3) + x(t+4) + x(t+5) + ...; x(t)= demand_gwh{p_end}
{txt}
{com}. label var demand_ma12 "12-month centred moving average demand"
{txt}
{com}. 
{txt}end of do-file

{com}. do "C:\Users\mary\AppData\Local\Temp\STD01000000.tmp"
{txt}
{com}. *
. * 3. KPI MONITORING SUMMARY TABLE
. *
. * Annual averages
. preserve
{txt}
{com}.     collapse (mean) generation_gwh demand_gwh peak_demand_mw ///
>              adequacy_ratio capacity_util_pct access_gap_pct ///
>              hydro_share_pct reliability_idx system_losses_pct ///
>              (sum) unmet_demand_gwh, by(year)
{txt}
{com}. 
.     * Round for reporting
.     foreach v of varlist adequacy_ratio capacity_util_pct access_gap_pct ///
>                          hydro_share_pct reliability_idx system_losses_pct {c -(}
{txt}  2{com}.         replace `v' = round(`v', 0.01)
{txt}  3{com}.     {c )-}
{txt}(7 real changes made)
(7 real changes made)
(7 real changes made)
(7 real changes made)
(7 real changes made)
(7 real changes made)

{com}.     foreach v of varlist generation_gwh demand_gwh unmet_demand_gwh {c -(}
{txt}  2{com}.         replace `v' = round(`v', 1)
{txt}  3{com}.     {c )-}
{txt}(7 real changes made)
(7 real changes made)
(7 real changes made)

