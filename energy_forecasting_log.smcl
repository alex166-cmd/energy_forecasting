{com}. * 5.3 KPSS test (manual interpretation note)
. * Stata does not have built-in KPSS; use zandrews as supplement
. * zandrews demand_gwh, break(trend)
. 
. *
. * 6. AUTOCORRELATION DIAGNOSTICS
. *
. * ACF and PACF — identify AR and MA orders
. ac  demand_gwh, lags(24) title("ACF — Monthly Demand") ///
>     graphregion(color(white)) bgcolor(white)
{res}{txt}
{com}. graph export "fig5_acf_demand.png", replace width(1000)
{txt}(file fig5_acf_demand.png written in PNG format)

{com}. 
. pac demand_gwh, lags(24) title("PACF — Monthly Demand") ///
>     graphregion(color(white)) bgcolor(white)
{res}{txt}
{com}. graph export "fig6_pacf_demand.png", replace width(1000)
{txt}(file fig6_pacf_demand.png written in PNG format)

{com}. 
. * ACF on first difference
. ac  D.demand_gwh, lags(24) title("ACF — First Difference of Demand") ///
>     graphregion(color(white)) bgcolor(white)
{res}{txt}
{com}. graph export "fig7_acf_diff_demand.png", replace width(1000)
{txt}(file fig7_acf_diff_demand.png written in PNG format)

{com}. 
{txt}end of do-file

{com}. do "C:\Users\mary\AppData\Local\Temp\STD01000000.tmp"
{txt}
{com}. *
. * 7. ARIMA / SARIMA MODEL FITTING
. *
. * Split: training = 2018m01–2023m12 (72 obs), test = 2024m01–2024m12 (12 obs)
. * We fit on training data and forecast 2024 to evaluate accuracy,
. * then refit on full data and forecast 2025.
. 
. * --- 7.1 Training window ---
. gen train = (t <= tm(2023m12))
{txt}
{com}. 
. * --- 7.2 Candidate models ---
. 
. * Model A: ARIMA(1,1,1) — baseline
. arima demand_gwh if train, arima(1,1,1)

