{txt}
{com}. *
. * 11. GENERATION FORECAST (proportional to demand, constrained by capacity)
. *
. * Simple approach: forecast generation as adequacy_ratio * forecast demand
. * (adequacy_ratio from training period)
. quietly summarize adequacy_ratio if train
{txt}
{com}. scalar mean_adequacy = r(mean)
{txt}
{com}. 
. gen generation_forecast = mean_adequacy * demand_forecast if t >= tm(2025m01)
{txt}(84 missing values generated)

{com}. replace generation_forecast = min(generation_forecast, capacity_mw * 24 * 30 / 1000)
{txt}(84 real changes made)

{com}. label var generation_forecast "Forecasted generation (GWh)"
{txt}
{com}. 
. tsline demand_forecast generation_forecast if t >= tm(2025m01), ///
>     title("Malawi 2025 Forecasted Demand vs Generation") ///
>     ytitle("GWh") xtitle("Month") ///
>     legend(label(1 "Demand forecast") label(2 "Generation forecast")) ///
>     lcolor(navy red) lwidth(medthick medthick) ///
>     graphregion(color(white)) bgcolor(white)
{res}{txt}
